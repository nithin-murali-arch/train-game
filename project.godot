; Engine Configuration for Rail Empire
; Godot version: 4.6.1.stable

[application]
config/name="Rail Empire"
config/description="Isometric 2D railway tycoon set in colonial India."
config/version="0.1.0"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"
run/main_scene="res://tests/sprint_17_acceptance.tscn"

[autoload]
GameState="*res://src/autoload/game_state.gd"
EventBus="*res://src/autoload/event_bus.gd"
EconomyManager="*res://src/autoload/economy_manager.gd"

[display]
window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

